# Application
APP_NAME=InsightHub
APP_ENV=development

# Server
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=8501

# LLM and retrieval
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
# To use Hugging Face Inference API instead, set your HF key:
# GROQ_API_KEY=hf_your_huggingface_api_key_here
# Note: HF keys start with "hf_" and will use meta-llama/Llama-3.1-8B-Instruct model
EMBEDDING_MODEL=BAAI/bge-m3
CHROMA_PATH=data/chroma
UPLOAD_PATH=data/uploads
SQLITE_PATH=data/insighthub.db
